# /etc/config/network — конфигурация прозрачного L2 моста
#
# Провайдер → [eth0] — br0 — [eth1] → Роутер → все устройства
#
# Management IP получается по DHCP от вышестоящего роутера.

config interface 'loopback'
    option device 'lo'
    option proto 'static'
    option ipaddr '127.0.0.1'
    option netmask '255.0.0.0'

config device 'br0'
    option name 'br0'
    option type 'bridge'
    option stp '0'
    list ports 'eth0'
    list ports 'eth1'

config interface 'bridge'
    option device 'br0'
    option proto 'dhcp'
