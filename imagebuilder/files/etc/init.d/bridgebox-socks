#!/bin/sh /etc/rc.common
# bridgebox-socks — SOCKS5 прокси для удалённого сканирования
#
# microsocks слушает на tailscale0 (mesh), трафик уходит через wlan0 (Wi-Fi к ISP).
# Нужен для удалённого запуска blockcheckw --via socks5://<ts_ip>:1080

START=96
STOP=14
USE_PROCD=1

PROG="/usr/bin/microsocks"
PORT=1080

get_iface_ip() {
    ip -4 addr show "$1" 2>/dev/null | grep -o 'inet [0-9.]*' | cut -d' ' -f2
}

start_service() {
    # Проверяем наличие microsocks
    [ -x "$PROG" ] || {
        logger -t bridgebox-socks "microsocks не найден, не запускаем"
        return 0
    }

    # Получаем IP адреса
    local ts_ip wlan_ip
    ts_ip=$(get_iface_ip tailscale0)
    wlan_ip=$(get_iface_ip wlan0)

    if [ -z "$ts_ip" ]; then
        logger -t bridgebox-socks "tailscale0 без IP, не запускаем"
        return 0
    fi

    if [ -z "$wlan_ip" ]; then
        logger -t bridgebox-socks "wlan0 без IP, не запускаем"
        return 0
    fi

    logger -t bridgebox-socks "Запуск: ${ts_ip}:${PORT}, bind=${wlan_ip}"

    procd_open_instance
    procd_set_param command "$PROG" -i "$ts_ip" -p "$PORT" -b "$wlan_ip"
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}
