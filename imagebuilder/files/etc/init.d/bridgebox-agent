#!/bin/sh /etc/rc.common
# bridgebox-agent — bb-agent daemon (DDD state machines)
#
# Agent — единственный оркестратор бизнес-логики на коробке.
# Управляет WiFi, Bridge, Mesh, Overlay через state machines.
# WebSocket к backend для realtime команд, HTTP heartbeat как fallback.

START=99
STOP=10

USE_PROCD=1

start_service() {
    # DNS upstream через dnsmasq — настраиваем forwarding на public DNS
    # dnsmasq слушает на 127.0.0.1, resolv.conf указывает на него.
    # Agent и sing-box резолвят через dnsmasq → upstream 8.8.8.8.
    if ! uci -q get dhcp.@dnsmasq[0].server | grep -q '8.8.8.8'; then
        uci add_list dhcp.@dnsmasq[0].server='8.8.8.8'
        uci add_list dhcp.@dnsmasq[0].server='1.1.1.1'
        uci set dhcp.@dnsmasq[0].noresolv='1'
        uci commit dhcp
    fi
    /etc/init.d/dnsmasq restart 2>/dev/null || true

    # Синхронизация часов перед стартом agent.
    # Без правильного времени TLS не работает → ни backend, ни Tailscale.
    # ntpd -n -q = one-shot sync, блокирующий. Таймаут 15 сек.
    if [ "$(date +%Y)" -lt 2026 ]; then
        logger -t bridgebox-agent "Часы отстают ($(date)), синхронизируем NTP..."
        ntpd -n -q -p pool.ntp.org -p time.google.com &
        NTP_PID=$!
        WAITED=0
        while kill -0 $NTP_PID 2>/dev/null && [ $WAITED -lt 15 ]; do
            sleep 1
            WAITED=$((WAITED + 1))
        done
        kill $NTP_PID 2>/dev/null || true
        logger -t bridgebox-agent "Время после NTP: $(date)"
    fi

    # Проверяем флаг safe mode (выставляется bridgebox-safe-mode при старте)
    local SAFE_MODE=""
    if [ -f /tmp/bridgebox-safe-mode ]; then
        SAFE_MODE="--safe-mode"
        logger -t bridgebox-agent "запуск в SAFE MODE"
    fi

    procd_open_instance
    procd_set_param command /usr/bin/bb-agent $SAFE_MODE
    procd_set_param respawn 3600 5 0
    procd_set_param stderr 1
    procd_set_param stdout 1
    procd_close_instance
}
