#!/bin/sh /etc/rc.common
# bridgebox-agent — регистрация устройства при загрузке
# Генерирует BOX_ID из MAC eth0, регистрируется на backend → статус UNCLAIMED

START=99

boot() {
    # Ждём сеть (Wi-Fi может подниматься дольше)
    local attempt=0
    while [ $attempt -lt 30 ]; do
        WLAN_STATE=$(cat /sys/class/net/wlan0/operstate 2>/dev/null)
        [ "$WLAN_STATE" = "up" ] && break
        attempt=$((attempt + 1))
        sleep 2
    done

    if [ "$WLAN_STATE" != "up" ]; then
        logger -t bb-agent "Wi-Fi не поднялся за 60 сек, регистрация отложена"
        return 1
    fi

    # DHCP + DNS (если ещё не получен)
    IP=$(ip -4 addr show wlan0 2>/dev/null | grep -o 'inet [0-9.]*' | cut -d' ' -f2)
    if [ -z "$IP" ]; then
        udhcpc -i wlan0 -q -t 5 -n 2>/dev/null
    fi
    echo "nameserver 8.8.8.8" > /tmp/resolv.conf

    # Запускаем регистрацию
    /usr/bin/bb-agent register 2>&1 | logger -t bb-agent
}
