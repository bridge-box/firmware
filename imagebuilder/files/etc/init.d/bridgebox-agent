#!/bin/sh /etc/rc.common
# bridgebox-agent — bb-agent daemon (DDD state machines)
#
# Agent — единственный оркестратор бизнес-логики на коробке.
# Управляет WiFi, Bridge, Mesh, Overlay через state machines.
# WebSocket к backend для realtime команд, HTTP heartbeat как fallback.

START=99
STOP=10

USE_PROCD=1

start_service() {
    # Fallback DNS — нужен до получения DNS от DHCP
    echo "nameserver 8.8.8.8" > /tmp/resolv.conf

    procd_open_instance
    procd_set_param command /usr/bin/bb-agent
    procd_set_param respawn 3600 5 0
    procd_set_param stderr 1
    procd_set_param stdout 1
    procd_close_instance
}
