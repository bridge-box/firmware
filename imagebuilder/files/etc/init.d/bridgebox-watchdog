#!/bin/sh /etc/rc.common
# bridgebox-watchdog — Hardware watchdog + периодическая проверка bridge
#
# Открывает /dev/watchdog (hardware watchdog начинает тикать)
# и запускает watchdog.sh каждые INTERVAL секунд.
# Если watchdog.sh не пнёт watchdog — коробка ребутнется.

START=95
USE_PROCD=1

INTERVAL=30
WATCHDOG_SCRIPT="/usr/lib/bridgebox/watchdog.sh"

start_service() {
    # Настраиваем hardware watchdog timeout (60с)
    if [ -c /dev/watchdog ]; then
        logger -t bridgebox-wd "Hardware watchdog активирован"
    else
        logger -t bridgebox-wd "WARN: /dev/watchdog не найден, только software watchdog"
    fi

    procd_open_instance
    procd_set_param command /bin/sh -c "while true; do sh $WATCHDOG_SCRIPT; sleep $INTERVAL; done"
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 0
    procd_set_param stderr 1
    procd_close_instance

    logger -t bridgebox-wd "Watchdog запущен (интервал: ${INTERVAL}с)"
}

stop_service() {
    logger -t bridgebox-wd "Watchdog остановлен"
}
