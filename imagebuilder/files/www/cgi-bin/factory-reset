#!/bin/sh
# factory-reset — CGI эндпоинт для сброса к заводским настройкам
# GET  → страница с кнопкой подтверждения
# POST → выполняет сброс

BOX_ID=$(cat /etc/bridgebox/box-id 2>/dev/null || echo "unknown")

# Определяем метод запроса
if [ "$REQUEST_METHOD" = "POST" ]; then
    # Выполняем factory reset
    echo "Content-Type: text/html; charset=utf-8"
    echo ""
    cat <<EOF
<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>BridgeBox — Сброс</title>
<style>
body { font-family: -apple-system, sans-serif; background: #0a0a0a; color: #e0e0e0; padding: 40px 20px; text-align: center; }
h1 { color: #facc15; margin-bottom: 16px; }
p { color: #aaa; }
</style>
</head>
<body>
<h1>Сброс выполняется...</h1>
<p>Коробка перезагружается. Подключитесь к Wi-Fi сети BridgeBox-* через 1-2 минуты.</p>
</body>
</html>
EOF
    # Запускаем сброс в фоне (чтобы HTTP ответ успел уйти)
    ( sleep 2 && /usr/lib/bridgebox/factory-reset.sh ) &
    exit 0
fi

# GET — показываем страницу с подтверждением
echo "Content-Type: text/html; charset=utf-8"
echo ""
cat <<EOF
<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>BridgeBox — Сброс к заводским настройкам</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: -apple-system, sans-serif; background: #0a0a0a; color: #e0e0e0; padding: 20px; }
.container { max-width: 480px; margin: 0 auto; text-align: center; padding-top: 40px; }
h1 { font-size: 1.4em; margin-bottom: 20px; }
.warning { background: #3a1a1a; border: 1px solid #f87171; border-radius: 12px; padding: 16px; margin-bottom: 24px; color: #f87171; }
.warning p { margin-bottom: 8px; }
.warning ul { text-align: left; padding-left: 20px; color: #e0e0e0; font-size: 0.9em; }
.warning li { margin-bottom: 4px; }
.btn-reset { background: #dc2626; color: white; border: none; padding: 14px 32px; border-radius: 8px; font-size: 1em; font-weight: 600; cursor: pointer; }
.btn-reset:hover { background: #b91c1c; }
.btn-back { display: inline-block; margin-top: 16px; color: #60a5fa; text-decoration: none; font-size: 0.9em; }
</style>
</head>
<body>
<div class="container">
<h1>Сброс к заводским настройкам</h1>
<div class="warning">
<p><strong>Это действие необратимо!</strong></p>
<ul>
<li>Wi-Fi настройки будут удалены</li>
<li>Привязка к аккаунту будет сброшена</li>
<li>Коробка вернётся в режим первоначальной настройки</li>
</ul>
</div>
<form method="POST">
<button type="submit" class="btn-reset" onclick="return confirm('Вы уверены? Коробка будет полностью сброшена.')">Сбросить к заводским настройкам</button>
</form>
<a href="/cgi-bin/status" class="btn-back">&larr; Назад к статусу</a>
</div>
</body>
</html>
EOF
